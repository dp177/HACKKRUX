# PostgreSQL Database
DATABASE_URL=postgresql://triage_user:triage_pass@postgres:5432/triage_db

# Redis Cache
REDIS_URL=redis://redis:6379/0

# Ollama LLM (Optional)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama2

# OpenAI API (Optional - if using GPT-4o instead of local LLM)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=5001
DEBUG=False
RELOAD=True

# Security
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001"]

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/triage.log

# Hospital Configuration
HOSPITAL_NAME=My Hospital
HOSPITAL_TYPE=multi-specialty
ENABLE_ANALYTICS=True

# Triage Configuration
ENABLE_RED_FLAG_ALERTS=True
RESCORE_INTERVAL_SECONDS=300
MAX_QUEUE_WAIT_CRITICAL=5
MAX_QUEUE_WAIT_HIGH=15
MAX_QUEUE_WAIT_MODERATE=45
MAX_QUEUE_WAIT_LOW=60

# Email Notifications (Optional)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# NOTIFICATION_EMAIL=admin@hospital.com
